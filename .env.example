# ComfyUI for DGX Spark (Blackwell GB10)
# Based on nvidia/cuda:13.1.1-devel-ubuntu24.04 container
# Customize your paths and rename this to .env
# I suggest creating a comfyui folder in your home
# Copy comfy_kitchen-0.2.7-cp312-abi3-linux_aarch64.whl in your /home/user/comfyui/wheel folder

# Base path where your existing ComfyUI installation lives (for models)
COMFYUI_HOST_PATH=/home/user/comfyui

# Base path for ComfyUI data (custom_nodes, outputs, inputs, etc.)
COMFYUI_DATA_PATH=/home/user/comfyui

# ComfyUI settings
COMFYUI_PORT=8188

# Optimized flags for Grace-Blackwell unified memory architecture
# Key: DON'T use --gpu-only - it fights the unified memory fabric
# --disable-pinned-memory: reduces overhead on unified fabric
# --force-fp16 + --fp16-*: enables Flash Attention optimization
# --dont-upcast-attention: keeps attention in FP16 for speed
# --disable-mmap: together with the patch in the Dockerfile fixes the double memory usage on unified memory on the Spark
COMFYUI_FLAGS=--listen 0.0.0.0 --port 8188 --normalvram --disable-dynamic-vram --reserve-vram 1 --disable-pinned-memory --use-sage-attention --force-fp16 --bf16-unet --bf16-vae --bf16-text-enc --dont-upcast-attention --disable-mmap

# Build refs (pin to specific commits/tags for reproducibility)
COMFYUI_REF=master

# ComfyUIMini - Mobile-friendly UI (optional)
# Access at http://<host>:3000
COMFYUIMINI_PORT=3000
COMFYUIMINI_REF=main
